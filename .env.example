# Dream Arabia — environment configuration
# Copy to .env and fill in. Every value has an offline-safe default, so the
# full build + test loop runs with NO keys and NO network.

# ---- LLM (agent core, Phase 6) -------------------------------------------
# Provider: "mock" (offline, deterministic) or "openrouter"
DREAM_LLM_PROVIDER=mock
OPENROUTER_API_KEY=
# Model id on OpenRouter (configurable). Default targets a Claude model.
DREAM_LLM_MODEL=anthropic/claude-3.7-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- Embeddings (Phase 5) -------------------------------------------------
# Provider: "fake" (offline, deterministic hash), "local" (sentence-transformers),
# or "openrouter"
DREAM_EMBED_PROVIDER=fake
DREAM_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Vector store (Phase 5) ----------------------------------------------
# "memory" (NumPy, default) or "pgvector"
DREAM_VECTOR_STORE=memory
PGVECTOR_DSN=

# ---- Scraping (Phase 3) — OFF by default ---------------------------------
# Live scraping is disabled unless this is explicitly "true".
DREAM_SCRAPE_LIVE=false
# Many .gov.sa URLs require a Saudi IP. Configure egress/proxy here.
DREAM_SCRAPE_PROXY=
DREAM_SCRAPE_EGRESS_REGION=

# ---- API / session (Phase 7) ---------------------------------------------
DREAM_SESSION_BACKEND=memory   # "memory" now; "redis" slot for production
REDIS_URL=
